rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // CUSTOM PURE CLIENT AUTHENTICATION MODEL
    // ===============================================================
    // Aplikasi ini menggunakan sistem login khusus menggunakan "Nama" dan "Device IP".
    // Tidak menggunakan Firebase Auth. request.auth selalu diset ke null.
    // Aturan di bawah ini menyesuaikan kebutuhan akses data berdasarkan "uid" lokal di dokumen.
    
    // PERINGATAN KEAMANAN: Memperbolehkan akses publik (read/write: true) memiliki risiko 
    // pada setup Firestore standar. Aplikasi ini mengandalkan filter query klien dan ID unik 
    // sebagai 'password' untuk membaca/menulis ke document.
    
    match /{document=**} {
      allow read: if true;
      allow write: if true;
    }
  }
}
