{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the UCP.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "CharacterStory": {
      "title": "Character Story",
      "description": "A character story submitted by a user.",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "characterName": { "type": "string" },
        "icLevel": { "type": "number" },
        "icAge": { "type": "number" },
        "statsImageUrl": { "type": "string" },
        "tabImageUrl": { "type": "string" },
        "originalText": { "type": "string" },
        "correctedText": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "adminFeedback": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "authorName", "characterName", "icLevel", "icAge", "statsImageUrl", "tabImageUrl", "originalText", "correctedText", "status", "createdAt", "updatedAt"]
    },
    "GlobalChat": {
      "title": "Global Chat",
      "description": "Messages in the global chat room.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "text": { "type": "string" },
        "sampId": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "text", "createdAt"]
    },
    "LoginLog": {
      "title": "Login Log",
      "description": "Audit trail of logins.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" },
        "browserId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["username", "timestamp", "status"]
    },
    "Ask": {
      "title": "Ask Admin",
      "description": "Questions asked by users to admins.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "answered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "question", "status", "createdAt", "updatedAt"]
    },
    "MetroKnowledge": {
      "title": "Metro Knowledge",
      "description": "Learned knowledge for Metro Bot.",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "category": { "type": "string" },
        "learnedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["question", "answer", "learnedAt"]
    },
    "AiLearning": {
      "title": "AI Learning",
      "description": "Positive/Negative examples for AI training.",
      "type": "object",
      "properties": {
        "originalText": { "type": "string" },
        "correctedText": { "type": "string" },
        "feedback": { "type": "string" },
        "type": { "type": "string", "enum": ["positive", "negative"] },
        "category": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "category"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles."
    },
    "/character_stories/{storyId}": {
      "schema": { "$ref": "#/entities/CharacterStory" },
      "description": "Stores submitted character stories."
    },
    "/global_chat/{messageId}": {
      "schema": { "$ref": "#/entities/GlobalChat" },
      "description": "Stores global chat messages."
    },
    "/asks/{askId}": {
      "schema": { "$ref": "#/entities/Ask" },
      "description": "Stores user questions to admins."
    },
    "/login_logs/{logId}": {
      "schema": { "$ref": "#/entities/LoginLog" },
      "description": "Stores login audit logs."
    },
    "/metro_knowledge/{knowledgeId}": {
      "schema": { "$ref": "#/entities/MetroKnowledge" },
      "description": "Learned knowledge for Metro Bot."
    },
    "/ai_learning/{learningId}": {
      "schema": { "$ref": "#/entities/AiLearning" },
      "description": "Training examples for AI."
    }
  }
}
